---
import { Image } from 'astro:assets';
import type { translations } from '../i18n/translations';
import heroImg from '../assets/steven-weeks-DUPFowqI6oI-unsplash.jpg';
import stepPhoto from '../assets/dan-meyers-IQVFVH0ajag-unsplash.jpg';
import stepDiag from '../assets/markus-spiske-iOL-0GJY-DM-unsplash.jpg';
import stepAmp from '../assets/polina-kuzovkova-0OkidWKbO2Q-unsplash.jpg';

interface Props {
  t: typeof translations[keyof typeof translations];
}

const { t } = Astro.props;
const whatsappUrl = `https://wa.me/5491122611627?text=${t.whatsappMessage}`;
const stepImages = [stepPhoto, stepDiag, stepAmp];
---

<!-- Nav -->
<nav>
  <div class="nav-inner">
    <a href="/" class="logo">
      <svg class="logo-icon" viewBox="0 0 64 64" fill="none">
        <rect width="64" height="64" rx="13" fill="rgba(168,216,0,0.12)"/>
        <path d="M14 16H50L22 48H50" stroke="#1A2208" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="50" cy="16" r="5" fill="#A8D800"/>
        <circle cx="50" cy="16" r="2.5" fill="#5A8800"/>
      </svg>
      <span class="wordmark">Z<em>ea</em></span>
    </a>
    <div class="nav-right">
      <a href="#how" class="nav-link">{t.nav.howItWorks}</a>
      <a href={t.langSwitch.href} class="nav-link">{t.langSwitch.label}</a>
      <a href={whatsappUrl} class="nav-cta" target="_blank">{t.nav.cta}</a>
    </div>
  </div>
</nav>

<!-- Hero -->
<section class="hero">
  <div class="hero-content">
    <span class="hero-label">{t.hero.label}</span>
    <h1>
      {t.hero.heading}
      <span class="highlight">{t.hero.headingHighlight}</span>
    </h1>
    <p class="hero-sub">{t.hero.sub}</p>
    <div class="hero-actions">
      <a href={whatsappUrl} class="btn-primary" target="_blank">{t.hero.cta}</a>
      <a href="#how" class="btn-ghost">{t.hero.secondary}</a>
    </div>
  </div>
  <div class="hero-image">
    <Image src={heroImg} alt="" width={640} quality={80} />
  </div>
</section>

<!-- Stats -->
<section class="stats-section">
  <div class="stats">
    {t.stats.map((stat) => (
      <div class="stat">
        <div class="stat-value">{stat.value}</div>
        <div class="stat-label">{stat.label}</div>
      </div>
    ))}
  </div>
</section>

<!-- How it works -->
<section class="section" id="how">
  <span class="section-label">{t.process.label}</span>
  <h2 class="section-title">{t.process.title}</h2>
  <div class="steps">
    {t.steps.map((step, i) => (
      <div class:list={['step', { 'step-reverse': i === 1 }]}>
        <div class="step-body">
          <span class="step-number">{step.number}</span>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </div>
        <div class="step-image">
          <Image src={stepImages[i]} alt={step.alt} width={560} quality={80} />
        </div>
      </div>
    ))}
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="cta-card">
    <span class="wordmark cta-wordmark">Z<em>ea</em></span>
    <p class="cta-tagline">{t.cta.tagline}</p>
    <a href={whatsappUrl} class="btn-primary btn-cta" target="_blank">{t.cta.button}</a>
  </div>
</section>

<footer>
  <p>{t.footer}</p>
</footer>

<style>
  /* ── Nav ── */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(250, 250, 246, 0.9);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
  }

  .logo-icon {
    width: 32px;
    height: 32px;
  }

  .wordmark {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 28px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .wordmark em {
    color: var(--primary-dark);
    font-style: italic;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-link:hover { color: var(--text); }

  .nav-cta {
    background: var(--text);
    color: var(--bg);
    padding: 10px 22px;
    border-radius: 10px;
    font-family: var(--font);
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .nav-cta:hover { opacity: 0.85; }

  /* ── Hero ── */
  .hero {
    padding: 140px 32px 80px;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 16px;
    display: block;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    color: var(--text);
  }

  h1 .highlight {
    color: var(--primary-dark);
    font-style: italic;
  }

  .hero-sub {
    font-size: 17px;
    color: var(--text-muted);
    max-width: 480px;
    line-height: 1.65;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--text);
    border: none;
    padding: 14px 28px;
    border-radius: 10px;
    font-family: var(--font);
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 24px var(--primary-glow);
  }

  .btn-ghost {
    color: var(--text);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    padding: 14px 20px;
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: border-color 0.2s, background 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--border-active);
    background: var(--bg-card);
  }

  .hero-image {
    border-radius: var(--radius);
    overflow: hidden;
  }

  .hero-image :global(img) {
    width: 100%;
    height: 400px;
    object-fit: cover;
    display: block;
  }

  /* ── Stats ── */
  .stats-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px 80px;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .stat {
    background: var(--bg-card);
    padding: 32px 24px;
    text-align: center;
  }

  .stat-value {
    font-family: var(--mono);
    font-size: 26px;
    font-weight: 500;
    color: var(--text);
  }

  .stat-label {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 6px;
  }

  /* ── Section ── */
  .section {
    padding: 80px 32px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
    display: block;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-bottom: 48px;
    color: var(--text);
  }

  /* ── Steps ── */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .step-reverse .step-image {
    order: -1;
  }

  .step-image {
    border-radius: var(--radius);
    overflow: hidden;
  }

  .step-image :global(img) {
    width: 100%;
    height: 340px;
    object-fit: cover;
    display: block;
  }

  .step-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .step-number {
    font-family: var(--mono);
    font-size: 48px;
    font-weight: 500;
    color: rgba(168, 216, 0, 0.2);
    line-height: 1;
    margin-bottom: 16px;
  }

  .step h3 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--text);
  }

  .step p {
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ── CTA ── */
  .cta-section {
    padding: 40px 32px 80px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .cta-card {
    background: var(--text);
    border-radius: var(--radius);
    padding: 64px 48px;
    text-align: center;
  }

  .cta-wordmark {
    font-size: 48px;
    color: var(--bg);
    display: block;
    margin-bottom: 8px;
  }

  .cta-wordmark em {
    color: var(--primary);
  }

  .cta-tagline {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(250, 250, 246, 0.4);
    margin-bottom: 32px;
  }

  .btn-cta {
    display: inline-block;
    background: var(--primary);
    color: var(--text);
    padding: 16px 36px;
    font-size: 16px;
  }

  /* ── Footer ── */
  footer {
    padding: 32px;
    text-align: center;
    color: var(--text-muted);
    font-size: 13px;
    border-top: 1px solid var(--border);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 120px 24px 60px;
    }

    .hero-image :global(img) {
      height: 260px;
    }

    .stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .step {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .step-reverse .step-image {
      order: 0;
    }

    .step-image :global(img) {
      height: 220px;
    }

    .cta-card {
      padding: 48px 24px;
    }
  }
</style>
