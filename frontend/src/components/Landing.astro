---
import { Image } from 'astro:assets';
import type { translations } from '../i18n/translations';
import heroImg from '../assets/steven-weeks-DUPFowqI6oI-unsplash.jpg';
import stepPhoto from '../assets/dan-meyers-IQVFVH0ajag-unsplash.jpg';
import stepDiag from '../assets/markus-spiske-iOL-0GJY-DM-unsplash.jpg';
import stepAmp from '../assets/polina-kuzovkova-0OkidWKbO2Q-unsplash.jpg';

interface Props {
  t: typeof translations[keyof typeof translations];
}

const { t } = Astro.props;
const whatsappUrl = `https://wa.me/5491122611627?text=${t.whatsappMessage}`;
const stepImages = [stepPhoto, stepDiag, stepAmp];
---

<!-- Nav -->
<nav>
  <div class="nav-inner">
    <a href="/" class="logo">
      <img src="/zea-logo.jpg" alt="Zea" class="logo-img" />
    </a>

    <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
      <svg class="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
      <svg class="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
    </button>

    <div class="nav-right">
      <a href="#how" class="nav-link">{t.nav.howItWorks}</a>

      <div class="lang-selector">
        <button class="lang-current" aria-label="Language">
          <span class="lang-flag">{t.lang === 'es' ? '🇦🇷' : '🇺🇸'}</span>
          <span class="lang-code">{t.lang === 'es' ? 'ES' : 'EN'}</span>
          <svg class="lang-chevron" width="10" height="6" viewBox="0 0 10 6"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
        </button>
        <div class="lang-dropdown">
          <a href="/" class:list={['lang-option', { active: t.lang === 'es' }]}>🇦🇷 Español</a>
          <a href="/en" class:list={['lang-option', { active: t.lang === 'en' }]}>🇺🇸 English</a>
        </div>
      </div>

      <a href={whatsappUrl} class="nav-cta" target="_blank">{t.nav.cta}</a>
    </div>
  </div>
</nav>

<!-- Hero -->
<section class="hero">
  <div class="hero-content">
    <span class="hero-label">{t.hero.label}</span>
    <h1>
      {t.hero.heading}
      <span class="highlight">{t.hero.headingHighlight}</span>
    </h1>
    <p class="hero-sub">{t.hero.sub}</p>
    <div class="hero-actions">
      <a href={whatsappUrl} class="btn-primary" target="_blank">{t.hero.cta}</a>
      <a href="#how" class="btn-ghost">{t.hero.secondary}</a>
    </div>
  </div>
  <div class="hero-image">
    <Image src={heroImg} alt="" width={640} quality={80} />
  </div>
</section>

<!-- Stats -->
<section class="stats-section">
  <div class="stats">
    {t.stats.map((stat) => (
      <div class="stat">
        <div class="stat-value">{stat.value}</div>
        <div class="stat-label">{stat.label}</div>
      </div>
    ))}
  </div>
</section>

<!-- How it works -->
<section class="section" id="how">
  <span class="section-label">{t.process.label}</span>
  <h2 class="section-title">{t.process.title}</h2>
  <div class="steps">
    {t.steps.map((step, i) => (
      <div class:list={['step', { 'step-reverse': i === 1 }]}>
        <div class="step-body">
          <span class="step-number">{step.number}</span>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </div>
        <div class="step-image">
          <Image src={stepImages[i]} alt={step.alt} width={560} quality={80} />
        </div>
      </div>
    ))}
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="cta-card">
    <span class="wordmark cta-wordmark">Z<em>ea</em></span>
    <p class="cta-tagline">{t.cta.tagline}</p>
    <a href={whatsappUrl} class="btn-primary btn-cta" target="_blank">{t.cta.button}</a>
  </div>
</section>

<footer>
  <p>{t.footer}</p>
</footer>

<style>
  /* ── Nav ── */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(250, 250, 246, 0.9);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .logo-img {
    height: 36px;
    width: 36px;
    border-radius: 8px;
    object-fit: cover;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 101;
    color: var(--text);
  }

  .icon-close { display: none; }
  .nav-toggle[aria-expanded="true"] .icon-menu { display: none; }
  .nav-toggle[aria-expanded="true"] .icon-close { display: block; }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-link:hover { color: var(--text); }

  /* Language selector */
  .lang-selector {
    position: relative;
  }

  .lang-current {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 6px 10px;
    cursor: pointer;
    font-family: var(--font);
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    transition: border-color 0.2s;
  }

  .lang-current:hover { border-color: var(--border-active); }

  .lang-flag { font-size: 16px; line-height: 1; }
  .lang-code { font-size: 12px; letter-spacing: 0.05em; }
  .lang-chevron { transition: transform 0.2s; color: var(--text-muted); }

  .lang-selector:hover .lang-chevron,
  .lang-selector:focus-within .lang-chevron { transform: rotate(180deg); }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 4px;
    min-width: 140px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: all 0.15s ease;
  }

  .lang-selector:hover .lang-dropdown,
  .lang-selector:focus-within .lang-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .lang-option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 7px;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    transition: background 0.15s;
  }

  .lang-option:hover { background: var(--bg-card); }
  .lang-option.active { background: rgba(168, 216, 0, 0.1); }

  .nav-cta {
    background: var(--text);
    color: var(--bg);
    padding: 10px 22px;
    border-radius: 10px;
    font-family: var(--font);
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .nav-cta:hover { opacity: 0.85; }

  /* ── Hero ── */
  .hero {
    padding: 140px 32px 80px;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 16px;
    display: block;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    color: var(--text);
  }

  h1 .highlight {
    color: var(--primary-dark);
    font-style: italic;
  }

  .hero-sub {
    font-size: 17px;
    color: var(--text-muted);
    max-width: 480px;
    line-height: 1.65;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--text);
    border: none;
    padding: 14px 28px;
    border-radius: 10px;
    font-family: var(--font);
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 24px var(--primary-glow);
  }

  .btn-ghost {
    color: var(--text);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    padding: 14px 20px;
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: border-color 0.2s, background 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--border-active);
    background: var(--bg-card);
  }

  .hero-image {
    border-radius: var(--radius);
    overflow: hidden;
  }

  .hero-image :global(img) {
    width: 100%;
    height: 400px;
    object-fit: cover;
    display: block;
  }

  /* ── Stats ── */
  .stats-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px 80px;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .stat {
    background: var(--bg-card);
    padding: 32px 24px;
    text-align: center;
  }

  .stat-value {
    font-family: var(--mono);
    font-size: 26px;
    font-weight: 500;
    color: var(--text);
  }

  .stat-label {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 6px;
  }

  /* ── Section ── */
  .section {
    padding: 80px 32px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
    display: block;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-bottom: 48px;
    color: var(--text);
  }

  /* ── Steps ── */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .step-reverse .step-image {
    order: -1;
  }

  .step-image {
    border-radius: var(--radius);
    overflow: hidden;
  }

  .step-image :global(img) {
    width: 100%;
    height: 340px;
    object-fit: cover;
    display: block;
  }

  .step-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .step-number {
    font-family: var(--mono);
    font-size: 48px;
    font-weight: 500;
    color: rgba(168, 216, 0, 0.2);
    line-height: 1;
    margin-bottom: 16px;
  }

  .step h3 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--text);
  }

  .step p {
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ── CTA ── */
  .cta-section {
    padding: 40px 32px 80px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .cta-card {
    background: var(--text);
    border-radius: var(--radius);
    padding: 64px 48px;
    text-align: center;
  }

  .cta-wordmark {
    font-size: 48px;
    color: var(--bg);
    display: block;
    margin-bottom: 8px;
  }

  .cta-wordmark em {
    color: var(--primary);
  }

  .cta-tagline {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(250, 250, 246, 0.4);
    margin-bottom: 32px;
  }

  .btn-cta {
    display: inline-block;
    background: var(--primary);
    color: var(--text);
    padding: 16px 36px;
    font-size: 16px;
  }

  /* ── Footer ── */
  footer {
    padding: 32px;
    text-align: center;
    color: var(--text-muted);
    font-size: 13px;
    border-top: 1px solid var(--border);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .nav-toggle {
      display: block;
    }

    .nav-right {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: 280px;
      background: var(--bg);
      flex-direction: column;
      align-items: stretch;
      padding: 80px 28px 32px;
      gap: 8px;
      border-left: 1px solid var(--border);
      box-shadow: -8px 0 32px rgba(0,0,0,0.1);
      transform: translateX(100%);
      transition: transform 0.25s ease;
      z-index: 100;
    }

    .nav-right.open {
      transform: translateX(0);
    }

    .nav-link {
      padding: 12px 0;
      font-size: 16px;
      border-bottom: 1px solid var(--border);
    }

    .nav-cta {
      width: 100%;
      text-align: center;
      margin-top: 12px;
    }

    /* On mobile, language selector is simple links, no hover dropdown */
    .lang-selector { width: 100%; }

    .lang-current { display: none; }

    .lang-dropdown {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: none;
      border: none;
      padding: 0;
      min-width: auto;
      display: flex;
      gap: 8px;
    }

    .lang-option {
      flex: 1;
      justify-content: center;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px;
    }

    .lang-selector:hover .lang-dropdown,
    .lang-selector:focus-within .lang-dropdown {
      transform: none;
    }

    .hero {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 120px 24px 60px;
    }

    .hero-image :global(img) {
      height: 260px;
    }

    .stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .step {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .step-reverse .step-image {
      order: 0;
    }

    .step-image :global(img) {
      height: 220px;
    }

    .cta-card {
      padding: 48px 24px;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const navRight = document.querySelector('.nav-right');
  if (toggle && navRight) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      navRight.classList.toggle('open');
    });
    // Close on link click
    navRight.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        navRight.classList.remove('open');
      });
    });
  }
</script>
